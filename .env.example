BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here

# Testnet (default): https://testnet.binancefuture.com
# Mainnet (live):    https://fapi.binance.com
BINANCE_BASE_URL=https://testnet.binancefuture.com

# Optional: require this token in Authorization header from TradingView alerts
# Set in TradingView alert message header: Authorization: Bearer your_token_here
WEBHOOK_SECRET=

# Railway sets PORT automatically — leave blank locally to use 3000
PORT=3000
